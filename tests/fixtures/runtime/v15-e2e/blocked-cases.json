{
  "id": "runtime.v15.blocked_cases",
  "cases": [
    {
      "name": "raw_yaml_authority_blocks_pre_plan",
      "registry_patch": {"authority": "raw_yaml"},
      "expect_pre_plan": "block",
      "expect_blocker_contains": "compiled JSON"
    },
    {
      "name": "stale_index_blocks_pre_plan",
      "registry_patch": {"deterministic_index_current": false},
      "expect_pre_plan": "block",
      "expect_blocker_contains": "deterministic index"
    },
    {
      "name": "planned_capability_blocks_pre_plan",
      "capability_readiness_patch": {"computed": "planned", "effective": "planned"},
      "expect_pre_plan": "block",
      "expect_blocker_contains": "not executable"
    },
    {
      "name": "draft_plan_cannot_install_for_agent_process",
      "plan_patch": {"status": "draft"},
      "expect_approve_plan": "block",
      "expect_blocker_contains": "approved"
    },
    {
      "name": "patch_outside_plan_blocks",
      "patch_patch": {"path": "vac-rs/crates/runtime/vac-broker/src/lib.rs"},
      "expect_patch": "block",
      "expect_blocker_contains": "outside Semantic Plan"
    },
    {
      "name": "forbidden_file_wins_over_allowed",
      "plan_patch": {"forbidden_files": ["vac-rs/crates/runtime/vac-agent-loop/src/bound_runtime.rs"]},
      "expect_patch": "block",
      "expect_blocker_contains": "forbidden.files wins"
    },
    {
      "name": "shell_runner_blocks_command",
      "command_patch": {"runner": "bash", "args": ["-lc", "cargo check"]},
      "expect_command": "block",
      "expect_blocker_contains": "free-form shell runner"
    },
    {
      "name": "destructive_command_requires_approval",
      "command_patch": {"runner": "rm", "args": ["-rf", "target/debug/incremental"], "risk": "high", "approval": "always", "policy_decision": "approval_required"},
      "expect_command": "approval_required"
    },
    {
      "name": "completion_lock_blocks_open_todo",
      "todo_patch": {"state": "open", "items": [{"id": "t.1", "text": "fix unresolved item", "kind": "test", "checked": false, "blocking": true}]},
      "expect_completion": "blocked",
      "expect_blocker_contains": "todo_terminal"
    },
    {
      "name": "l1_cannot_claim_l2_fail_closed",
      "claim_l2": true,
      "expect_enforcement_honesty": "block",
      "expect_blocker_contains": "L2 fail-closed claim is invalid"
    }
  ]
}
