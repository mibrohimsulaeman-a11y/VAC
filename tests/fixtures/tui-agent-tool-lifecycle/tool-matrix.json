  "required_visible_markers": [
    "VAC_AGENT_TOOL_RESULT run_command",
    "VAC_AGENT_TOOL_RESULT run_command_task",
    "VAC_AGENT_TOOL_RESULT run_remote_command",
    "VAC_AGENT_TOOL_RESULT run_remote_command_task",
    "VAC_AGENT_TOOL_RESULT get_all_tasks",
    "VAC_AGENT_TOOL_RESULT wait_for_tasks",
    "VAC_AGENT_TOOL_RESULT get_task_details",
    "VAC_AGENT_TOOL_RESULT cancel_task",
    "VAC_AGENT_TOOL_RESULT view",
    "VAC_AGENT_TOOL_RESULT str_replace",
    "VAC_AGENT_TOOL_RESULT create",
    "VAC_AGENT_TOOL_RESULT remove",
    "VAC_AGENT_TOOL_RESULT view_web_page",
    "VAC_AGENT_TOOL_RESULT generate_password",
    "VAC_AGENT_ASK_USER_POPUP_SHOWN",
    "VAC_AGENT_ASK_USER_OPTION_SELECTED",
